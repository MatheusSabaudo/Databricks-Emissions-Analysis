{
  "datasets": [
    {
      "name": "2ea60781",
      "displayName": "Location Data",
      "queryLines": [
        "SELECT \n",
        "  latitude,\n",
        "  longitude,\n",
        "  `GHG emissions mtons CO2e` AS emissions\n",
        "FROM emissions.default.emissions_data"
      ],
      "catalog": "emissions",
      "schema": "default"
    },
    {
      "name": "72790ce1",
      "displayName": "Emissions_per_person",
      "queryLines": [
        "SELECT \n",
        "  county_state_name,\n",
        "  population,\n",
        "  `GHG emissions mtons CO2e` AS emissions,\n",
        "  ROUND(TRY_CAST(REPLACE(`GHG emissions mtons CO2e`, ',', '') AS DOUBLE) / NULLIF(TRY_CAST(REPLACE(population, ',', '') AS DOUBLE), 0), 3) AS emissions_per_person\n",
        "FROM emissions.default.emissions_data\n",
        "ORDER BY emissions_per_person DESC"
      ],
      "catalog": "emissions",
      "schema": "default"
    },
    {
      "name": "21257356",
      "displayName": "Total_Emissions_Per_State",
      "queryLines": [
        "SELECT \n",
        "    state_abbr,\n",
        "    SUM(CAST(REPLACE(`GHG emissions mtons CO2e`, ',', '') AS DOUBLE)) AS Total_Emissions\n",
        "FROM emissions.default.emissions_data\n",
        "GROUP BY state_abbr\n",
        "ORDER BY total_emissions DESC;"
      ]
    }
  ],
